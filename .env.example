APP_NAME=inference-trace-explorer
ENV=dev
TRACE_SAMPLE_RATE=1.0
SQLITE_PATH=./data/trace_store.db
JSONL_TRACE_PATH=./data/traces/traces.jsonl
ACTIVATION_DIR=./data/activations
ENABLE_REDIS=false
REDIS_URL=redis://redis:6379/0

# Provider keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

API_BASE_URL=http://localhost:8000
ANALYTICS_ROLLUP_PATH=./data/analytics/rollups.jsonl
ROLLUP_INTERVAL_SECONDS=60
